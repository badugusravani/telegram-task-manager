<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= description %>">
    <link rel="stylesheet" href="/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <header class="header">
        <nav class="nav">
            <div class="nav-container">
                <a href="/" class="nav-logo">CopyPasteTools</a>
                <div class="nav-links">
                    <a href="/" class="nav-link">Home</a>
                    <a href="/tools" class="nav-link">Tools</a>
                    <a href="/about" class="nav-link">About</a>
                </div>
            </div>
        </nav>
    </header>

    <main class="main">
        <div class="container">
            <div class="error-page">
                <div class="error-content">
                    <h1 class="error-title">500 - Server Error</h1>
                    <p class="error-description">Something went wrong. Please try again later.</p>
                    <div class="error-actions">
                        <a href="/" class="btn btn-primary">Go Home</a>
                        <button onclick="location.reload()" class="btn btn-outline">Try Again</button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 CopyPasteTools. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>