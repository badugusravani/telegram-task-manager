<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= description %>">
    <meta name="keywords" content="copy paste, text generator, online tools, free utilities">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://yourdomain.com/">
    
    <!-- Open Graph -->
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description" content="<%= description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://yourdomain.com/">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= title %>">
    <meta name="twitter:description" content="<%= description %>">
    
    <link rel="stylesheet" href="/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <header class="header">
        <nav class="nav">
            <div class="nav-container">
                <a href="/" class="nav-logo">CopyPasteTools</a>
                <div class="nav-links">
                    <a href="/" class="nav-link active">Home</a>
                    <a href="/tools" class="nav-link">Tools</a>
                    <a href="/about" class="nav-link">About</a>
                </div>
            </div>
        </nav>
    </header>

    <main class="main">
        <div class="container">
            <div class="hero">
                <h1 class="hero-title">Free Online Copy Paste Tools</h1>
                <p class="hero-description">Generate text, symbols, and content instantly. Copy and paste anywhere you need it.</p>
                <div class="hero-buttons">
                    <a href="#tools" class="btn btn-primary">Explore Tools</a>
                    <a href="#popular" class="btn btn-outline">Popular Tools</a>
                </div>
            </div>

            <section id="tools" class="tools-section">
                <h2 class="section-title">Popular Tools</h2>
                <div class="tools-grid">
                    <% keywords.forEach(function(keyword) { %>
                        <a href="/<%= keyword.slug %>" class="tool-card">
                            <div class="tool-icon">
                                <% if (keyword.category === 'love') { %>
                                    <span>❤️</span>
                                <% } else if (keyword.category === 'apology') { %>
                                    <span>🙏</span>
                                <% } else if (keyword.category === 'calculator') { %>
                                    <span>💰</span>
                                <% } else if (keyword.category === 'emoji') { %>
                                    <span>😊</span>
                                <% } else { %>
                                    <span>📝</span>
                                <% } %>
                            </div>
                            <div class="tool-content">
                                <h3 class="tool-title"><%= keyword.title %></h3>
                                <p class="tool-description"><%= keyword.description.substring(0, 120) %>...</p>
                                <div class="tool-meta">
                                    <span class="tool-category"><%= keyword.category %></span>
                                </div>
                            </div>
                        </a>
                    <% }); %>
                </div>
            </section>

            <section class="categories-section">
                <h2 class="section-title">Browse by Category</h2>
                <div class="categories-grid">
                    <a href="/category/love" class="category-card">
                        <h3>❤️ Love & Romance</h3>
                        <p>Generate romantic messages and love expressions</p>
                    </a>
                    <a href="/category/apology" class="category-card">
                        <h3>🙏 Apologies</h3>
                        <p>Create sincere apology messages</p>
                    </a>
                    <a href="/category/calculator" class="category-card">
                        <h3>💰 Calculators</h3>
                        <p>Salary, date, and conversion calculators</p>
                    </a>
                    <a href="/category/emoji" class="category-card">
                        <h3>😊 Emojis & Symbols</h3>
                        <p>Copy emojis and special characters</p>
                    </a>
                </div>
            </section>

            <section class="features-section">
                <h2 class="section-title">Why Choose Our Tools?</h2>
                <div class="features-grid">
                    <div class="feature-card">
                        <div class="feature-icon">⚡</div>
                        <h3>Instant Generation</h3>
                        <p>Generate content instantly with our fast and reliable tools</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">🔒</div>
                        <h3>100% Free</h3>
                        <p>All tools are completely free to use, no registration required</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">📱</div>
                        <h3>Mobile Friendly</h3>
                        <p>Works perfectly on all devices and screen sizes</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">🎯</div>
                        <h3>SEO Optimized</h3>
                        <p>All pages are optimized for search engines</p>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>CopyPasteTools</h3>
                    <p>Free online tools for copy paste content, text generators, and utilities.</p>
                </div>
                <div class="footer-section">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/tools">All Tools</a></li>
                        <li><a href="/sitemap.xml">Sitemap</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Categories</h4>
                    <ul>
                        <li><a href="/category/love">Love Tools</a></li>
                        <li><a href="/category/apology">Apology Tools</a></li>
                        <li><a href="/category/calculator">Calculators</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 CopyPasteTools. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script>
        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Add loading animation to tool cards
        document.querySelectorAll('.tool-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-5px)';
            });
            
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0)';
            });
        });
    </script>
</body>
</html>