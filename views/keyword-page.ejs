<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= description %>">
    <meta name="keywords" content="<%= keyword.tags.join(', ') %>">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://yourdomain.com/<%= keyword.slug %>">
    
    <!-- Open Graph -->
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description" content="<%= description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://yourdomain.com/<%= keyword.slug %>">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= title %>">
    <meta name="twitter:description" content="<%= description %>">
    
    <link rel="stylesheet" href="/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <header class="header">
        <nav class="nav">
            <div class="nav-container">
                <a href="/" class="nav-logo">CopyPasteTools</a>
                <div class="nav-links">
                    <a href="/" class="nav-link">Home</a>
                    <a href="/tools" class="nav-link">Tools</a>
                    <a href="/about" class="nav-link">About</a>
                </div>
            </div>
        </nav>
    </header>

    <main class="main">
        <div class="container">
            <div class="breadcrumb">
                <a href="/">Home</a>
                <span>/</span>
                <a href="/category/<%= keyword.category %>"><%= keyword.category %></a>
                <span>/</span>
                <span><%= keyword.title %></span>
            </div>

            <div class="hero">
                <h1 class="hero-title"><%= keyword.title %></h1>
                <p class="hero-description"><%= keyword.description %></p>
                <div class="keyword-meta">
                    <span class="meta-item">
                        <strong>Search Volume:</strong> <%= keyword.searchVolume.toLocaleString() %>
                    </span>
                    <span class="meta-item">
                        <strong>Difficulty:</strong> <%= keyword.difficulty %>/100
                    </span>
                    <span class="meta-item">
                        <strong>Category:</strong> <%= keyword.category %>
                    </span>
                </div>
            </div>

            <div class="tool-section">
                <div class="tool-card">
                    <h2 class="tool-title">Generated Content</h2>
                    <div class="content-area">
                        <textarea id="generatedContent" class="content-textarea" readonly><%= keyword.content %></textarea>
                        <div class="button-group">
                            <button onclick="copyToClipboard()" class="btn btn-primary">Copy to Clipboard</button>
                            <button onclick="selectAll()" class="btn btn-secondary">Select All</button>
                            <button onclick="clearContent()" class="btn btn-outline">Clear</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="info-section">
                <div class="info-card">
                    <h3>About This Tool</h3>
                    <p>This free online tool generates "<%= keyword.keyword %>" content that you can copy and paste anywhere. Perfect for social media, messages, and creative projects.</p>
                </div>
                
                <div class="info-card">
                    <h3>How to Use</h3>
                    <ol>
                        <li>Click "Copy to Clipboard" to copy the generated content</li>
                        <li>Paste it wherever you need it</li>
                        <li>Use "Select All" to manually select the text</li>
                        <li>Use "Clear" to clear the text area</li>
                    </ol>
                </div>

                <div class="info-card">
                    <h3>SEO Information</h3>
                    <ul>
                        <li><strong>Search Volume:</strong> <%= keyword.searchVolume.toLocaleString() %> monthly searches</li>
                        <li><strong>Competition:</strong> <%= keyword.difficulty %>/100 difficulty</li>
                        <li><strong>Features:</strong> <%= keyword.features.join(', ') %></li>
                        <li><strong>Last Updated:</strong> <%= keyword.lastUpdated %></li>
                    </ul>
                </div>
            </div>

            <div class="related-tools">
                <h3>Related Tools</h3>
                <div class="tools-grid">
                    <% relatedKeywords.forEach(function(related) { %>
                        <a href="/<%= related.slug %>" class="tool-link">
                            <div class="tool-item">
                                <h4><%= related.title %></h4>
                                <p><%= related.description.substring(0, 100) %>...</p>
                                <div class="tool-meta">
                                    <span class="tool-category"><%= related.category %></span>
                                    <span class="tool-volume"><%= related.searchVolume.toLocaleString() %> searches</span>
                                </div>
                            </div>
                        </a>
                    <% }); %>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>CopyPasteTools</h3>
                    <p>Free online tools for copy paste content, text generators, and utilities.</p>
                </div>
                <div class="footer-section">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/tools">All Tools</a></li>
                        <li><a href="/sitemap.xml">Sitemap</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Categories</h4>
                    <ul>
                        <li><a href="/category/love">Love Tools</a></li>
                        <li><a href="/category/apology">Apology Tools</a></li>
                        <li><a href="/category/calculator">Calculators</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 CopyPasteTools. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script>
        function copyToClipboard() {
            const textarea = document.getElementById('generatedContent');
            textarea.select();
            document.execCommand('copy');
            
            // Show success message
            const button = event.target;
            const originalText = button.textContent;
            button.textContent = 'Copied!';
            button.classList.add('btn-success');
            
            setTimeout(() => {
                button.textContent = originalText;
                button.classList.remove('btn-success');
            }, 2000);
        }

        function selectAll() {
            const textarea = document.getElementById('generatedContent');
            textarea.select();
        }

        function clearContent() {
            const textarea = document.getElementById('generatedContent');
            textarea.value = '';
        }

        // Auto-resize textarea
        const textarea = document.getElementById('generatedContent');
        textarea.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = this.scrollHeight + 'px';
        });

        // Initialize textarea height
        window.addEventListener('load', function() {
            textarea.style.height = 'auto';
            textarea.style.height = textarea.scrollHeight + 'px';
        });
    </script>
</body>
</html>